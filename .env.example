# ─── Application ──────────────────────────────────────
NODE_ENV=development
APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
PORT=3000

# ─── Database ──────────────────────────────────────────
# Neon PostgreSQL connection string (or local Postgres for dev)
DATABASE_URL=postgresql://user:password@host:5432/db?sslmode=require

# ─── Redis ─────────────────────────────────────────────
# Upstash Redis connection string (ioredis format)
REDIS_URL=redis://default:password@host:6379

# ─── Authentication ────────────────────────────────────
# REQUIRED in production. Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
# Must be at least 32 characters.
JWT_SECRET=change-me-to-a-random-48-byte-base64-string

# ─── Initial admin user (created on first boot if no users exist) ──
# In production, this MUST be set. Defaults to a generated random value
# if missing, in which case the user must reset the password on first login.
ADMIN_EMAIL=admin@posystem.com
ADMIN_PASSWORD=change-me-on-first-deploy

# ─── Optional ──────────────────────────────────────────
# Toggle demo credentials pre-fill on the login page (development only)
NEXT_PUBLIC_DEMO_MODE=true